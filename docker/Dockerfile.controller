FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    openvswitch-common \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
COPY src/ src/

RUN pip install --no-cache-dir .

EXPOSE 6653 8080

CMD ["ryu-manager", "src/sdn_ddos_detector/controller/ddos_controller.py"]
